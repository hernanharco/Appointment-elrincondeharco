---
// src/pages/login.astro
// Responsabilidad única: página de login con Google OAuth

const redirectParam    = Astro.url.searchParams.get('redirect') ?? '/';
const GOOGLE_CLIENT_ID = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID;

const token = Astro.cookies.get('access_token')?.value;
if (token) {
  return Astro.redirect(redirectParam);
}

// Rutas del proxy local — sin depender de api.ts
const ROUTE_AUTH_GOOGLE = '/api/auth/google';
const ROUTE_PENDING     = '/pending';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Iniciar sesión — CoreAppointment</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #09090b;
      --surface: #111114;
      --surface-2: #18181c;
      --border: #222227;
      --text: #e8eaf0;
      --muted: #4a4b55;
      --muted-2: #6b6c78;
      --accent: #4a6cf7;
      --google-border: #2a2a30;
      --google-hover: #1c1c22;
      --error: #f87171;
      --error-bg: rgba(248,113,113,0.07);
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
      overflow: hidden;
    }

    .bg-grid {
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(74,108,247,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(74,108,247,0.04) 1px, transparent 1px);
      background-size: 48px 48px;
      pointer-events: none;
      mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 40%, transparent 100%);
    }

    .bg-glow {
      position: fixed;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 700px; height: 700px;
      background: radial-gradient(circle, rgba(74,108,247,0.07) 0%, transparent 65%);
      pointer-events: none;
    }

    .card {
      position: relative;
      z-index: 1;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 2.75rem 2.25rem 2.25rem;
      width: 100%;
      max-width: 400px;
      box-shadow:
        0 0 0 1px rgba(255,255,255,0.03) inset,
        0 40px 100px rgba(0,0,0,0.7),
        0 8px 32px rgba(0,0,0,0.4);
      animation: appear 0.3s cubic-bezier(0.34, 1.2, 0.64, 1);
    }

    @keyframes appear {
      from { opacity: 0; transform: translateY(20px) scale(0.97); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 2.25rem;
    }

    .brand-icon {
      width: 32px; height: 32px;
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .brand-dot {
      width: 10px; height: 10px;
      border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 12px var(--accent);
    }

    .brand-name {
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: var(--muted-2);
    }

    h1 {
      font-size: 1.75rem;
      font-weight: 700;
      letter-spacing: -0.04em;
      line-height: 1.2;
      margin-bottom: 6px;
    }

    h1 span {
      background: linear-gradient(135deg, #e8eaf0 30%, #6b7280);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .subtitle {
      font-size: 13.5px;
      color: var(--muted-2);
      margin-bottom: 2.25rem;
      line-height: 1.5;
    }

    .error-banner {
      display: flex;
      align-items: flex-start;
      gap: 8px;
      background: var(--error-bg);
      border: 1px solid rgba(248,113,113,0.2);
      border-radius: 10px;
      color: var(--error);
      font-size: 13px;
      padding: 10px 12px;
      margin-bottom: 1.25rem;
      line-height: 1.4;
    }

    .google-btn {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      background: var(--surface-2);
      border: 1px solid var(--google-border);
      border-radius: 12px;
      color: var(--text);
      font-family: inherit;
      font-size: 14.5px;
      font-weight: 500;
      padding: 13px 20px;
      cursor: pointer;
      transition: background 0.15s, border-color 0.15s, transform 0.1s, box-shadow 0.15s;
      position: relative;
      overflow: hidden;
    }

    .google-btn::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(255,255,255,0.03), transparent);
      pointer-events: none;
    }

    .google-btn:hover:not(:disabled) {
      background: var(--google-hover);
      border-color: #363640;
      transform: translateY(-1px);
      box-shadow: 0 4px 20px rgba(0,0,0,0.3);
    }

    .google-btn:active:not(:disabled) { transform: translateY(0); box-shadow: none; }
    .google-btn:disabled { opacity: 0.6; cursor: not-allowed; }

    .spinner {
      width: 16px; height: 16px;
      border: 2px solid rgba(255,255,255,0.2);
      border-top-color: rgba(255,255,255,0.7);
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
      flex-shrink: 0;
    }

    @keyframes spin { to { transform: rotate(360deg); } }
    .google-logo { flex-shrink: 0; }

    .security-badge {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      margin-top: 1.5rem;
      font-size: 11.5px;
      color: var(--muted);
    }
  </style>
</head>
<body>
  <div class="bg-grid"></div>
  <div class="bg-glow"></div>

  <div class="card">
    <div class="brand">
      <div class="brand-icon"><span class="brand-dot"></span></div>
      <span class="brand-name">CoreAppointment</span>
    </div>

    <h1><span>Bienvenido de vuelta</span></h1>
    <p class="subtitle">Accede a tu panel de administración con tu cuenta de Google.</p>

    <div id="error-container" style="display:none" class="error-banner">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
        <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.2"/>
        <path d="M7 4v3M7 9v.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
      <span id="error-msg"></span>
    </div>

    <button id="google-btn" class="google-btn" type="button">
      <svg class="google-logo" width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M17.64 9.205c0-.639-.057-1.252-.164-1.841H9v3.481h4.844a4.14 4.14 0 0 1-1.796 2.716v2.259h2.908c1.702-1.567 2.684-3.875 2.684-6.615Z" fill="#4285F4"/>
        <path d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18Z" fill="#34A853"/>
        <path d="M3.964 10.71A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332Z" fill="#FBBC05"/>
        <path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58Z" fill="#EA4335"/>
      </svg>
      <span>Continuar con Google</span>
    </button>

    <div class="security-badge">
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
        <path d="M6 1L2 2.5v4c0 2.5 1.8 4.2 4 4.8 2.2-.6 4-2.3 4-4.8v-4L6 1z" stroke="currentColor" stroke-width="1"/>
      </svg>
      Conexión segura · Solo administradores
    </div>
  </div>

  <script src="https://accounts.google.com/gsi/client" async defer></script>

  <script define:vars={{ redirectParam, GOOGLE_CLIENT_ID, ROUTE_AUTH_GOOGLE, ROUTE_PENDING }}>

    const btn            = document.getElementById('google-btn');
    const errorContainer = document.getElementById('error-container');
    const errorMsg       = document.getElementById('error-msg');
    const origin         = window.location.hostname + window.location.pathname;

    const GOOGLE_SVG = `
      <svg class="google-logo" width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M17.64 9.205c0-.639-.057-1.252-.164-1.841H9v3.481h4.844a4.14 4.14 0 0 1-1.796 2.716v2.259h2.908c1.702-1.567 2.684-3.875 2.684-6.615Z" fill="#4285F4"/>
        <path d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18Z" fill="#34A853"/>
        <path d="M3.964 10.71A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332Z" fill="#FBBC05"/>
        <path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58Z" fill="#EA4335"/>
      </svg>
      <span>Continuar con Google</span>`;

    function showError(msg) {
      errorMsg.textContent = msg;
      errorContainer.style.display = 'flex';
      setLoading(false);
    }

    function setLoading(loading) {
      btn.disabled = loading;
      btn.innerHTML = loading
        ? '<span class="spinner"></span><span>Verificando…</span>'
        : GOOGLE_SVG;
    }

    async function handleGoogleCode(code) {
      setLoading(true);
      errorContainer.style.display = 'none';

      try {
        // ✅ Proxy local — misma origin que Astro
        const response = await fetch(ROUTE_AUTH_GOOGLE, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ token: code, origin }),
        });

        const data = await response.json().catch(() => ({}));

        if (data.detail === 'PENDING_APPROVAL') {
          window.location.href = ROUTE_PENDING;
          return;
        }

        if (!response.ok) {
          throw new Error(data.detail || `Error ${response.status}`);
        }

        window.location.href = redirectParam;

      } catch (err) {
        showError(err.message || 'No se pudo conectar con el servidor');
      }
    }

    function initGoogleAuth() {
      if (!window.google) { setTimeout(initGoogleAuth, 100); return; }

      if (!GOOGLE_CLIENT_ID) {
        console.error('❌ Falta PUBLIC_GOOGLE_CLIENT_ID en .env');
        return;
      }

      btn.addEventListener('click', () => {
        errorContainer.style.display = 'none';
        const client = google.accounts.oauth2.initCodeClient({
          client_id: GOOGLE_CLIENT_ID,
          scope: 'openid email profile',
          ux_mode: 'popup',
          callback: (response) => {
            if (response.code) {
              handleGoogleCode(response.code);
            } else {
              showError('No se recibió código de autorización de Google');
            }
          },
          error_callback: (error) => {
            if (error.type !== 'popup_closed') {
              showError('Error al abrir Google: ' + (error.message || error.type));
            }
            setLoading(false);
          },
        });
        client.requestCode();
      });
    }

    document.addEventListener('DOMContentLoaded', initGoogleAuth);
  </script>
</body>
</html>